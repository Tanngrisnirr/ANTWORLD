{
  "project": "AntWorld ML - Body Part Detection",
  "version": "0.1.0",
  "task": "object_detection",
  "model": {
    "architecture": "SSD_MobileNetV2",
    "input_size": [320, 320, 3],
    "backbone": "MobileNetV2",
    "pretrained": true
  },
  "classes": [
    "head",
    "mesosoma",
    "metasoma",
    "petiole",
    "antenna",
    "leg"
  ],
  "training": {
    "epochs": 100,
    "batch_size": 8,
    "learning_rate": 0.001,
    "validation_split": 0.2,
    "augmentation": {
      "horizontal_flip": true,
      "rotation_range": 15,
      "zoom_range": 0.1,
      "brightness_range": [0.8, 1.2]
    }
  },
  "paths": {
    "annotations": "../TrainingSets/annotations/",
    "images": "../TrainingSets/images/",
    "models": "./models/detection/",
    "tfjs_output": "../antworld.org/alpha/js/ml/ant_detector/"
  },
  "inference": {
    "confidence_threshold": 0.5,
    "nms_threshold": 0.4
  }
}
