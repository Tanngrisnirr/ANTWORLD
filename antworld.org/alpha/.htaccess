# mod_rewrite on
RewriteEngine on
RewriteCond %{HTTPS} !on

# Delete the /index
RewriteBase /alpha/

RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s(.*?/+)index\.html(?:/(.*))?[\s?] [NC]
RewriteRule ^ %1%2 [L,R]

# Redirect /index to clean folder URL
RewriteRule ^(.*)/index$ /$1/ [R=301,L]

# Hotlinking Protection (allows empty referer and localhost)
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^https?://(www\.)?antworld\.org [NC]
RewriteCond %{HTTP_REFERER} !^https?://localhost(:[0-9]+)? [NC]
RewriteRule \.(js|css|jpg|gif|png|bmp|mp4|3gp|m4a|m4r|aac|mp3|ogg|wave)$ - [F]

# PHP code in HTML file
AddType fcgid-script .php .htm .html .phtml

# Remove html extension
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L,QSA]

# 301 from example.com/page.html to example.com/page
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /.*\.html\ HTTP/
RewriteRule ^(.*)\.html$ $1 [R=301,L]

## EXPIRES CACHING ##
<filesMatch ".(jpg|jpeg|png|gif)$">
Header set Cache-Control "max-age=300, public"
</filesMatch>
<filesMatch ".(ico)$">
Header set Cache-Control "max-age=97200, public"
</filesMatch>
