# mod_rewrite on
RewriteEngine on

# ============================================
# HTTPS & WWW REDIRECTS (production only)
# ============================================

# Force HTTPS (only on production domain, not localhost)
RewriteCond %{HTTPS} !on
RewriteCond %{HTTP_HOST} ^(www\.)?antworld\.org$ [NC]
RewriteRule ^(.*)$ https://antworld.org/$1  [R=301,L]

# Redirect www to non-www (always use canonical non-www)
RewriteCond %{HTTP_HOST} ^www\.antworld\.org$ [NC]
RewriteRule ^(.*)$ https://antworld.org/$1  [R=301,L]

# ============================================
# DELETED PAGES (410 Gone - remove from index)
# ============================================

# Obsolete pages permanently removed
RewriteRule ^access\.php$ - [G,L]
RewriteRule ^annuler_paiement(\.html)?$ - [G,L]
RewriteRule ^paiement_confirme(\.html)?$ - [G,L]
RewriteRule ^id/acropyga_ergate_old(\.html)?$ - [G,L]
RewriteRule ^id/acropyga_rhyzomyrma2_ergate_old(\.html)?$ - [G,L]
RewriteRule ^id/acropyga_test(\.html)?$ - [G,L]

# ============================================
# LEGACY URL REDIRECTS (GCS 404 fixes)
# ============================================

# Old id/species/references/ paths -> zdocs/
RewriteRule ^id/species/references/A\ new\ slave-making\ ant\ from\ Japan\ Yano\ 1911\.pdf$ "zdocs/Yano 1911 - A new slave-making ant from Japan.pdf" [R=301,L,B]
RewriteRule ^id/species/references/Sociobiology\ of\ slave\ making\ ants\ -\ Patricia\ D\ 2001\.pdf$ "zdocs/D'Ettorre 2001 - Sociobiology of slave-making ants.pdf" [R=301,L,B]
RewriteRule ^id/species/references/formica_slave_against_polyergus_rufescens_imago_gerhard_heller_2004\.pdf$ "zdocs/Heller 2004 - Formica sanguinea slave defense against Polyergus rufescens.pdf" [R=301,L,B]

# Old docs/ folder renamed to zdocs/
RewriteRule ^docs/(.*)$ zdocs/$1 [R=301,L]

# Renamed PDF redirect (old long name -> new short name)
RewriteRule ^zdocs/Jaitrong\ 2013\ -\ The\ Army\ Ant\ Aenictus\ wroughtonii\ and\ related\ species\ in\ the\ Oriental\ region\ with\ descriptions\ of\ two\ new\ species\.\ Japanese\ Journal\ of\ Systematic\ Entomology\.pdf$ "zdocs/Jaitrong 2013 - Aenictus wroughtonii and related species in the Oriental region.pdf" [R=301,L,B]

# ============================================
# CASE SENSITIVITY & TYPO FIXES
# ============================================

# Case fix: littleFormicinae -> littleformicinae
RewriteRule ^id/littleFormicinae_ergate(\.html)?$ id/littleformicinae_ergate [R=301,L]

# Case fix: Training -> training
RewriteRule ^Training(\.html)?$ training [R=301,L]

# Typo fix: lasinii -> lasiini
RewriteRule ^id/lasinii_ergate(\.html)?$ id/lasiini_ergate  [R=301,L]

# ============================================
# MISSING PAGES -> PARENT REDIRECTS
# ============================================

# Austrolasius species -> Lasius
RewriteRule ^id/austrolasius_(austriacus|carniolicus|reginae)_ergate(\.html)?$ id/lasius_ergate  [R=301,L]

# Cerapachys species -> Cerapachys
RewriteRule ^id/cerapachys_(biroi|hashimotoi|daikoku|humicola)_ergate(\.html)?$ id/cerapachys_ergate  [R=301,L]

# Acropyga species -> Acropyga
RewriteRule ^id/acropyga_(atopodon|rhyzomyrma1)_ergate(\.html)?$ id/acropyga_ergate  [R=301,L]

# Dorylus -> pdf_ergate (Dorylinae key)
RewriteRule ^id/dorylus_fulvus_ergate(\.html)?$ id/pdf_ergate  [R=301,L]

# Myrmicinae subpages -> Myrmicinae
RewriteRule ^id/(crematogaster|strong_mandibules)_ergate(\.html)?$ id/myrmicinae_ergate  [R=301,L]

# Cautolasius -> cauto&chthonolasius
RewriteRule ^id/cautolasius_ergate(\.html)?$ id/cauto%26chthonolasius_ergate [R=301,L,NE]

# Polyergus shortcuts -> species pages
RewriteRule ^id/P_nigerrimus(\.html)?$ id/species/polyergus_nigerrimus_ergate  [R=301,L]
RewriteRule ^id/P_samurai(\.html)?$ id/species/polyergus_samurai_ergate  [R=301,L]
RewriteRule ^id/P_breviceps(\.html)?$ id/species/polyergus_rufescens_ergate  [R=301,L]

# ============================================
# GENERA -> SUBFAMILY REDIRECTS
# ============================================

# Formicinae genera -> formicinae_ergate
RewriteRule ^id/(camponotus|formica|proformica|cataglyphis|bajcaridris|formicinii)(\.html)?$ id/formicinae_ergate  [R=301,L]

# Lasiini/Plagiolepini genera -> littleformicinae_ergate
RewriteRule ^id/(nylanderia|prenolepis|plagiolepis|lepisiota|paratrechina|plagiolepinii)(\.html)?$ id/littleformicinae_ergate  [R=301,L]

# Anoplolepis -> lasiini_ergate
RewriteRule ^id/anoplolepis(\.html)?$ id/lasiini_ergate  [R=301,L]

# Broken _ergate link (empty genus)
RewriteRule ^id/_ergate(\.html)?$ id/confirmed.ergate_id  [R=301,L]

# ============================================
# URL CLEANUP
# ============================================

# Delete the /index
RewriteBase /alpha/

RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s(.*?/+)index\.html(?:/(.*))?[\s?] [NC]
RewriteRule ^ %1%2 [L,R]

# Redirect /index to clean folder URL
RewriteRule ^(.*)/index$ /$1/  [R=301,L]

# Hotlinking Protection (allows empty referer, localhost, and partner sites)
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^https?://(www\.)?antworld\.org [NC]
RewriteCond %{HTTP_REFERER} !^https?://localhost(:[0-9]+)? [NC]
RewriteCond %{HTTP_REFERER} !^https?://biomedisa\.info [NC]
RewriteRule \.(js|css|jpg|gif|png|bmp|mp4|3gp|m4a|m4r|aac|mp3|ogg|wave)$ - [F]

# PHP code in HTML file
AddType fcgid-script .php .htm .html .phtml

# Remove html extension
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L,QSA]

# 301 from example.com/page.html to example.com/page
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /.*\.html\ HTTP/
RewriteRule ^(.*)\.html$ $1  [R=301,L]

## EXPIRES CACHING ##
<filesMatch ".(jpg|jpeg|png|gif)$">
Header set Cache-Control "max-age=300, public"
</filesMatch>
<filesMatch ".(ico)$">
Header set Cache-Control "max-age=97200, public"
</filesMatch>
