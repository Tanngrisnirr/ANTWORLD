# mod_rewrite on
RewriteEngine on

# PHP code in HTML file - inherit from root .htaccess
# Root uses: AddType fcgid-script .html
# No need to override here

# Hotlinking Protection (only for production)
# RewriteCond %{HTTP_REFERER} !^$
# RewriteCond %{HTTP_REFERER} !^http://(www\.)?antworld.org/.*$ [NC]
# RewriteRule \.(js|css|jpg|gif|png|bmp|mp4|3gp|m4a|m4r|aac|mp3|ogg|wave)$ - [F]

# URL rewriting rules (disabled for local development)
# Uncomment for production if clean URLs are desired

# # Remove html extension
# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteCond %{REQUEST_FILENAME}.html -f
# RewriteRule ^(.+)$ $1.html [L,QSA]

# # 301 from example.com/page.html to example.com/page
# RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /.*\.html\ HTTP/
# RewriteRule ^(.*)\.html$ /$1 [R=301,L]

